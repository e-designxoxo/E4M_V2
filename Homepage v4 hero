<script>
/* ── Nav ── */
const nb = document.getElementById('navbar');
let ticking = false;
window.addEventListener('scroll', ()=>{
  if(!ticking){
    requestAnimationFrame(()=>{
      nb.classList.toggle('is-scrolled', scrollY > 60);
      ticking = false;
    });
    ticking = true;
  }
}, {passive:true});

function toggleNav(id){
  const el=document.getElementById(id), was=el.classList.contains('is-open');
  document.querySelectorAll('.nav__item.is-open').forEach(n=>{
    n.classList.remove('is-open');
    n.querySelector('[aria-expanded]').setAttribute('aria-expanded','false');
  });
  if(!was){el.classList.add('is-open');el.querySelector('[aria-expanded]').setAttribute('aria-expanded','true')}
}
document.addEventListener('click', e=>{
  if(!e.target.closest('.nav__item'))
    document.querySelectorAll('.nav__item.is-open').forEach(n=>{
      n.classList.remove('is-open');
      n.querySelector('[aria-expanded]').setAttribute('aria-expanded','false');
    });
});
document.addEventListener('keydown', e=>{
  if(e.key==='Escape')
    document.querySelectorAll('.nav__item.is-open').forEach(n=>{
      n.classList.remove('is-open');
      n.querySelector('[aria-expanded]').setAttribute('aria-expanded','false');
    });
});
const hbg=document.getElementById('hamburger'), drw=document.getElementById('mobile-drawer');
function toggleMobile(){const o=drw.classList.toggle('is-open');hbg.classList.toggle('is-open',o);hbg.setAttribute('aria-expanded',String(o));document.body.style.overflow=o?'hidden':''}
function toggleMobSection(id){document.getElementById(id).classList.toggle('is-open')}

/* ── Pillars: auto-cycle + hover ── */
const pillars = document.querySelectorAll('.pillar');
const progressBar = document.getElementById('progressBar');
const CYCLE_MS = 4200;
let current = 0;
let timer;
let paused = false;

function activate(i){
  current = i;
  pillars.forEach((p, j) => p.classList.toggle('is-active', j === i));
  /* Progress bar jumps to position */
  progressBar.style.transform = `translateX(${i * 100}%)`;
}

function startTimer(){
  clearInterval(timer);
  timer = setInterval(()=>{
    if(!paused) activate((current+1) % pillars.length);
  }, CYCLE_MS);
}

pillars.forEach((p, i) => {
  /* Hover — expand and pause */
  p.addEventListener('mouseenter', ()=>{
    paused = true;
    activate(i);
  });
  p.addEventListener('mouseleave', ()=>{
    paused = false;
    startTimer();
  });
  /* Click: if not active, expand instead of navigate */
  p.addEventListener('click', e=>{
    if(i !== current){ e.preventDefault(); activate(i); }
    /* if already active, href fires normally */
  });
});

activate(0);
startTimer();
</script>
